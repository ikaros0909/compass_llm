{
  "name": "compass-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:migrate": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "dev:setup": "python3 scripts/gen-dev-schema.py && DATABASE_URL=file:./dev.db prisma db push --schema prisma/schema.dev.prisma --skip-generate && prisma generate --schema prisma/schema.dev.prisma",
    "dev:local": "npm run dev:setup && DATABASE_URL=file:./dev.db next dev"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.6.3",
    "lucide-react": "^0.460.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.49",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  }
}
