# ── 로컬 개발용 환경 변수 (Docker 없이 SQLite + 로컬 Ollama) ──
# 사용법: cp .env.local.example .env.local  후 값 수정
# (운영/도커 배포는 루트의 .env.example + docker-compose 를 사용합니다)

# SQLite DB 파일 (npm run dev:setup 이 생성)
DATABASE_URL="file:./dev.db"

# 로컬에서 직접 실행 중인 Ollama / 워커 주소
OLLAMA_BASE_URL="http://127.0.0.1:11434"
WORKER_BASE_URL="http://127.0.0.1:8100"

# 세션 서명 키 (아무 문자열, 운영에선 openssl rand -hex 32)
AUTH_SECRET="local-dev-secret"

# 최초 부팅 시 자동 생성되는 관리자 계정
ADMIN_EMAIL="admin@compass.local"
ADMIN_PASSWORD="devpass"

# 지표 수집 주기(ms)
METRICS_INTERVAL_MS="5000"
