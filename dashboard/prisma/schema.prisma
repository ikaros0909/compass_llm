generator client {
  provider      = "prisma-client-js"
  // 로컬(native) + 도커 런타임(Debian/OpenSSL3) 엔진 모두 생성
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin") // admin | viewer
  // 세션 무효화 토큰: 값이 바뀌면 기존 JWT 세션이 모두 만료된다.
  // (로그아웃·비밀번호 변경·역할 변경 시 증가)
  sessionEpoch Int      @default(0)
  createdAt    DateTime @default(now())
}

model ApiKey {
  id          String       @id @default(cuid())
  name        String
  apiKey      String       // 표시용 prefix (예: sk-3e54a8…fd3e). 비밀 아님
  secretHash  String       @unique // sha256(토큰) — 단일 토큰 조회 키
  isActive    Boolean      @default(true)
  rateLimit   Int          @default(30)
  createdAt   DateTime     @default(now())
  requestLogs RequestLog[]
}

model RequestLog {
  id           BigInt   @id @default(autoincrement())
  apiKeyId     String?
  apiKey       ApiKey?  @relation(fields: [apiKeyId], references: [id])
  endpoint     String
  model        String?
  status       Int
  latencyMs    Int
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  clientIp     String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([apiKeyId, createdAt])
}

model MetricSample {
  id          BigInt   @id @default(autoincrement())
  gpuIndex    Int
  utilization Float
  memUsedMb   Int
  memTotalMb  Int
  tempC       Float
  powerW      Float
  loadedModel String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model RagCollection {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  fileCount   Int      @default(0)
  createdAt   DateTime @default(now())
}

// 코드리뷰 설정 (싱글턴, id="default"). token 은 서버 전용 — 클라이언트에 노출하지 않음.
model CodeReviewConfig {
  id           String   @id @default("default")
  provider     String   @default("bitbucket_cloud")
  workspace    String   @default("jinhaksa")
  repoSlugs    String   @default("") // 쉼표로 구분된 저장소 slug 목록 (다중 선택)
  authUsername String   @default("") // App Password 사용 시 Basic 인증용 (비우면 Access Token=Bearer)
  token        String   @default("") // Access Token 또는 App Password
  model        String   @default("") // 설치된 Ollama 모델
  intervalMin  Int      @default(10)
  enabled      Boolean  @default(false)
  autoApprove  Boolean  @default(false) // 중대한 문제 없으면 PR 자동 승인
  systemPrompt String   @default("")
  updatedAt    DateTime @updatedAt
}

// 코드리뷰 이력 (재리뷰 중복 방지 + 화면 표시)
model CodeReviewLog {
  id         BigInt   @id @default(autoincrement())
  repoSlug   String   @default("")
  prId       Int
  prTitle    String   @default("")
  prAuthor   String   @default("") // PR 요청자(display_name)
  headCommit String   @default("")
  diffHash   String   @default("") // 변경 내용(diff) 해시 — 커밋이 바뀌어도 코드가 같으면 재리뷰 안 함
  status     String   // posted | error
  approval   String   @default("") // "" 미사용 | approved | changes | failed
  // 코드 품질 척도 (모델이 리뷰 끝에 [[META]] JSON 으로 산출)
  qualityScore  Int?     // 1~5 (5=매우 우수)
  riskLevel     String   @default("") // low | medium | high (버그·보안 문제 가능성)
  confidence    String   @default("") // low | medium | high (모델 판단 확신도)
  needsReview   Boolean  @default(false) // 자동승인이어도 사람이 다시 볼 것을 권장
  reviewReasons String   @default("") // 감점·우려 사유 JSON 배열
  message    String   @default("") // 요약 또는 오류
  commentId  String?
  createdAt  DateTime @default(now())

  @@index([repoSlug, prId, headCommit])
  @@index([createdAt])
}
