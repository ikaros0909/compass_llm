# ── Compass LLM 환경 변수 ──
# install.sh 가 이 파일을 복사해 .env 를 만들고 비밀값을 채웁니다.

# 접속 주소: 도메인이 있으면 example.com (자동 HTTPS), 없으면 :80 (내부망 HTTP)
SITE_ADDRESS=:80

# Postgres
POSTGRES_USER=compass
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=compass

# 대시보드 세션 서명 키 (openssl rand -hex 32)
AUTH_SECRET=change-me-64-hex-chars

# 최초 부팅 시 생성되는 관리자 계정
ADMIN_EMAIL=admin@compass.local
ADMIN_PASSWORD=change-me-admin-password

# (선택) 화자분리(pyannote) 사용 시 HuggingFace 토큰
HF_TOKEN=
